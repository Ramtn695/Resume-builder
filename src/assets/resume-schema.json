            "isVisible": true,
            "optional": false,
            "class": "form-input"
          },
          {
            "id": "description",
            "control": "textarea",
            "type": "text",
            "placeholder": "Job Description / Responsibilities",
            "validators": [],
            "styles": { "width": "500px", "height": "100px" },
            "isVisible": true,
            "optional": true,
            "class": "form-textarea"
          }
        ]
