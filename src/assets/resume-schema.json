            "isVisible": true,
            "optional": false,
            "class": "form-input"
          },
          {
            "id": "location",
            "control": "input",
            "type": "text",
            "placeholder": "Location",
            "validators": [],
            "styles": { "width": "250px" },
            "isVisible": true,
            "optional": true,
            "class": "form-input"
