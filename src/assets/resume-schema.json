          },
          {
            "id": "duration",
            "control": "input",
            "type": "text",
            "placeholder": "Duration (e.g., Sep 2002 - Jun 2007)",
            "validators": [],
            "styles": { "width": "250px" },
            "isVisible": true,
            "optional": true,
            "class": "form-input"
