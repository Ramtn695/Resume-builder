{
  "form": {
    "sections": [
      {
        "id": "personalInformation",
        "title": "Personal Information",
        "fields": [
          {
            "id": "fullName",
            "control": "input",
            "type": "text",
            "placeholder": "Full Name",
            "validators": ["required"],
            "styles": { "width": "250px" },
            "isVisible": true,
            "optional": false,
            "class": "form-input"
          },
          {
            "id": "address",
            "control": "textarea",
            "type": "text",
            "placeholder": "Address",
            "validators": ["required"],
            "styles": { "width": "400px", "height": "60px" },
            "isVisible": true,
            "optional": false,
            "class": "form-textarea"
          },
          {
            "id": "phoneNumber",
            "control": "input",
            "type": "tel",
            "placeholder": "Phone Number",
            "validators": ["required", "phone"],
            "styles": { "width": "250px" },
            "isVisible": true,
            "optional": false,
            "class": "form-input"
          },
          {
            "id": "emailAddress",
            "control": "input",
            "type": "email",
            "placeholder": "Email Address",
            "validators": ["required", "email"],
            "styles": { "width": "250px" },
            "isVisible": true,
            "optional": false,
            "class": "form-input"
          },
          {
            "id": "drivingLicense",
            "control": "input",
            "type": "text",
            "placeholder": "Driving License",
            "validators": [],
            "styles": { "width": "250px" },
            "isVisible": true,
            "optional": true,
            "class": "form-input"
          },
          {
            "id": "linkedin",
            "control": "input",
            "type": "url",
            "placeholder": "LinkedIn Profile",
            "validators": ["url"],
            "styles": { "width": "250px" },
            "isVisible": true,
            "optional": true,
            "class": "form-input"
          }
        ]
      },
      {
        "id": "summary",
        "title": "Professional Summary",
        "fields": [
          {
            "id": "profileSummary",
            "control": "textarea",
